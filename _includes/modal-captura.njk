<div class="modal-overlay" id="modalCaptura" role="dialog"
     aria-modal="true" aria-labelledby="modalTitulo"
     onclick="fecharModalFora(event)">
  <div class="modal">
    <button class="modal__fechar" onclick="fecharModal()" aria-label="Fechar">
      <i class="fa-solid fa-xmark" aria-hidden="true"></i>
    </button>
    <div class="modal__icone" aria-hidden="true">📥</div>
    <h3 id="modalTitulo">Onde enviamos o material?</h3>
    <span class="tagline" id="modalSubtitulo">Preencha e receba o PDF gratuitamente no seu e-mail.</span>
    <form id="formCaptura" onsubmit="submeterCaptura(event)">
      <div class="form-grupo">
        <label for="capturaNome">Seu nome</label>
        <input type="text" id="capturaNome" placeholder="Ex: Maria da Silva" required />
      </div>
      <div class="form-grupo">
        <label for="capturaEmail">Seu e-mail</label>
        <input type="email" id="capturaEmail" placeholder="maria@email.com" required />
      </div>
      <button type="submit" class="btn btn-primario btn-lg w-full">
        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i> Enviar e baixar
      </button>
    </form>
    <div class="mensagem-sucesso" id="mensagemSucessoModal">
      <div class="mensagem-sucesso__icone">✅</div>
      <h3 style="color:var(--cat-bem-estar)">Material enviado!</h3>
      <p>Verifique sua caixa de entrada (e a pasta de spam, por via das dúvidas).</p>
    </div>
    <p class="modal__aviso">Você também receberá dicas exclusivas. Pode cancelar quando quiser.</p>
  </div>
</div>
